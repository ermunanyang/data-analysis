# 环境变量配置模板
# 复制此文件为 .env.local 并根据需要修改

# 数据库配置
# SQLite 数据库：使用相对路径
DATABASE_URL="file:./prisma/dev.db"

# 如果需要使用 MariaDB/MySQL，取消下面的注释并修改配置
# DATABASE_URL="mysql://username:password@localhost:3306/database_name"

# Node.js 内存配置（根据您的电脑内存调整，单位MB）
NODE_OPTIONS="--max-old-space-size=4096"

# Next.js 配置
# 开发模式
NEXT_PUBLIC_DEVELOPMENT_MODE=true
# 生产模式设置为 false
# NEXT_PUBLIC_DEVELOPMENT_MODE=false

# 日志级别：debug, info, warn, error
NEXT_LOG_LEVEL=warn

# 是否禁用 Webpack 缓存（遇到问题时可以设为 true）
NEXT_DISABLE_WEBPACK_CACHE=false

# 服务器端口（可选，默认 3000）
# PORT=3000

# 管理员配置（仅用于初始化，实际密码存储在数据库中）
INITIAL_ADMIN_USERNAME="admin"
INITIAL_ADMIN_PASSWORD="admin123"