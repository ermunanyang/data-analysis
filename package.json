{
  "name": "data",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:optimized": "@powershell -Command $env:NODE_OPTIONS='--max-old-space-size=4096'; next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "clean": "rm -rf node_modules .next pnpm-lock.yaml && pnpm cache clean",
    "reinstall": "pnpm run clean && pnpm install",
    "check:types": "tsc --noEmit",
    "check:health": "pnpm run check:types && pnpm run lint",
    "db:push": "prisma db push",
    "db:generate": "prisma generate",
    "db:studio": "prisma studio",
    "db:seed": "tsx prisma/seed-admin.ts"
  },
  "dependencies": {
    "@ant-design/cssinjs": "^2.1.0",
    "@ant-design/icons": "^5.5.0",
    "@ant-design/nextjs-registry": "^1.0.1",
    "@prisma/adapter-mariadb": "^7.8.0",
    "@prisma/client": "^6.19.0",
    "antd": "^5.24.2",
    "critters": "^0.0.25",
    "exceljs": "^4.4.0",
    "jszip": "^3.10.1",
    "mariadb": "^3.5.2",
    "next": "16.2.1",
    "prisma": "^6.19.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "tailwindcss": "^4",
    "tsx": "^4.19.0",
    "typescript": "^5"
  }
}
